ENVIRONMENT=local
QDRANT_URL=http://localhost:6333

# Настройки LLM (по умолчанию используем Groq API, так как он быстрый, бесплатный и совместим с OpenAI)
LLM_API_KEY=твой_секретный_ключ_здесь
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama3-8b-8192

# SQLite база данных для истории чатов
DATABASE_URL=sqlite+aiosqlite:///./chat_history.db